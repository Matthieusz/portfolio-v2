---
import Github from "@/icons/Github.astro";
import Link from "@/icons/Link.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import ProjectBanner from "@/components/ProjectBanner.astro";
import Gallery from "@/components/Gallery";
import { slugify } from "@/lib/utils";
import { getCollection, getEntry, render } from "astro:content";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

export const getStaticPaths = async () => {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: slugify(project.data.title) },
    props: { projectId: project.id },
  }));
};

const { projectId } = Astro.props;

const project =
  typeof projectId === "string" ? await getEntry("projects", projectId) : null;

if (!project) {
  return Astro.redirect("/projects");
}

const { Content } = await render(project);
const { date, demoLink, repoLink, tags, title } = project.data;

const projectDir = project.id.split("/")[0];

const allGlobs = import.meta.glob("/src/content/projects/**/*.png", {
  eager: true,
});

const rawImages = Object.entries(allGlobs)
  .filter(([path]) =>
    path.toLowerCase().includes(`/projects/${projectDir.toLowerCase()}/`),
  )
  .map(([path, mod]) => {
    const filename = path.split("/").pop()!;
    const name = filename.replace(/\.[^/.]+$/, "");

    const timestampMatch = filename.match(/(\d{4}-\d{2}-\d{2})/);
    const timestamp = timestampMatch
      ? new Date(timestampMatch[1]).getTime()
      : 0;

    return {
      mod: mod as Record<string, unknown>,
      name,
      timestamp,
    };
  })
  .sort((a, b) => b.timestamp - a.timestamp);

const imageEntries = await Promise.all(
  rawImages.map(async (img) => {
    const meta = img.mod.default as ImageMetadata;
    const optimized = await getImage({
      src: meta,
      format: "webp",
      quality: 80,
    });
    return {
      src: optimized.src,
      name: img.name,
      timestamp: img.timestamp,
    };
  }),
);

const hasImages = imageEntries.length > 0;
---

<MainLayout>
  <article class="mx-auto mb-12 max-w-4xl overflow-hidden rounded-lg">
    <ProjectBanner title={title} id={project.id} compact={false} />
    <div class="p-6">
      <header class="mb-6 space-y-3">
        <h1
          class="text-3xl font-bold"
          transition:name={`project-${project.id}-title`}
        >
          {title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 text-sm">
          <time datetime={date.toISOString()}>{date.toLocaleDateString()}</time>
          {
            repoLink ? (
              <a
                class="link-underline flex items-center gap-1"
                href={repoLink}
                rel="noopener noreferrer"
                target="_blank"
              >
                <Github size={16} color="currentColor" />
                Repository
              </a>
            ) : null
          }
          {
            demoLink ? (
              <a
                class="link-underline flex items-center gap-1"
                href={demoLink}
                rel="noopener noreferrer"
                target="_blank"
              >
                <Link size={16} color="currentColor" />
                Live demo
              </a>
            ) : null
          }
          {hasImages && <Gallery images={imageEntries} client:load />}
        </div>
        <div class="flex flex-wrap gap-2">
          {
            tags.map((tag) => (
              <span class="bg-secondary text-secondary-foreground rounded-full px-3 py-1 text-xs">
                {tag}
              </span>
            ))
          }
        </div>
      </header>

      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </article>
</MainLayout>
