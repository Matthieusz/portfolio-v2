---
import Hashtag from "@/icons/Hashtag.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { Image } from "astro:assets";
import AboutMePic from "../content/images/me.jpg";
---

<MainLayout>
  <section class="mx-auto my-12 flex max-w-6xl flex-col items-start gap-4">
    <h1 class="flex items-center gap-2 text-4xl font-bold">
      <Hashtag /> About Me
    </h1>
    <div class="flex w-full gap-4">
      <div class="w-[40%]">
        <Image src={AboutMePic} alt="Mateusz Irski" width={400} height={400} />
      </div>
      <div class="w-[60%]">
        <p class="mt-4 text-lg">
          Hi! I'm Mateusz, a software developer with a passion for creating
          innovative solutions. I have experience mainly in Typescript and
          various frameworks (recently loving Tanstack Start though), and I
          enjoy working on both frontend and backend projects. When I'm not
          coding you can catch me swimming, reading or playing some games with
          friends.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
